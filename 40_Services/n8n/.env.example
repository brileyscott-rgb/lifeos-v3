# =============================================================================
# n8n Environment Variables — Example Only
# =============================================================================
# Copy this file to .env and fill in real values.
# .env is gitignored — do not commit secrets.
# =============================================================================

# n8n server configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Basic authentication (recommended for local-only access)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=change_me
N8N_BASIC_AUTH_PASSWORD=change_me

# Timezone
GENERIC_TIMEZONE=America/Chicago
TZ=America/Chicago

# =============================================================================
# Future placeholders — uncomment and fill when activating related features
# =============================================================================

# Public webhook URL (do not configure until ready for production webhook use)
# WEBHOOK_URL=https://example.com/

# Telegram bot token (store in n8n credential store, not in env)
# TELEGRAM_BOT_TOKEN=do_not_put_real_token_here

# OpenAI / LLM API keys (store in n8n credential store, not in env)
# OPENAI_API_KEY=do_not_put_real_key_here
