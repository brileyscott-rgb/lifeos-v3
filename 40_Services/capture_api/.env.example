# LifeOS Capture API environment variables
# Copy to .env and replace with a real token:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# Do not commit .env. It is gitignored.

LIFEOS_CAPTURE_HOST=127.0.0.1
LIFEOS_CAPTURE_PORT=8789
LIFEOS_CAPTURE_BEARER_TOKEN=REPLACE_WITH_GENERATED_TOKEN
LIFEOS_CAPTURE_REQUIRE_AUTH=true
LIFEOS_CAPTURE_MAX_BYTES=65536
LIFEOS_CAPTURE_QUEUE_PATH=/home/lifeos/LifeOS_Capture_Buffer/00_Raw/captures.jsonl
