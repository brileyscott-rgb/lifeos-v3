# Telegram Bot API token from BotFather.
# Copy this file to an ignored .env file later.
TELEGRAM_BOT_TOKEN=replace_with_real_token_locally_never_commit

# Optional allowed Telegram user ID.
TELEGRAM_ALLOWED_USER_ID=replace_with_your_numeric_telegram_user_id

# Future n8n webhook placeholder.
N8N_TELEGRAM_CAPTURE_WEBHOOK_URL=http://localhost:5678/webhook/telegram-capture-placeholder

# Runtime mode.
TELEGRAM_CHATOPS_MODE=scaffold_only
